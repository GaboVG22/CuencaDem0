# Opción A: formato recomendado para Earth Engine en Streamlit Cloud.
[earthengine]
type = "service_account"
project_id = "id-proyecto-google-cloud"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nPEGAR_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
client_email = "cuenta-servicio@id-proyecto-google-cloud.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/cuenta-servicio%40id-proyecto-google-cloud.iam.gserviceaccount.com"

# Opción B: formato plano alternativo.
# EE_SERVICE_ACCOUNT = "cuenta-servicio@id-proyecto-google-cloud.iam.gserviceaccount.com"
# EE_PRIVATE_KEY = "-----BEGIN PRIVATE KEY-----\nPEGAR_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
